{
  "bindings": {
    "/actions/main": {
      "sources": [
        {
          "path": "/user/hand/left/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/toggle_panel" }
          }
        },
        {
          "path": "/user/hand/right/input/b",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/toggle_panel" }
          }
        },
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/interact" }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/interact" }
          }
        },
        {
          "path": "/user/hand/left/input/a",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/decrement" }
          }
        },
        {
          "path": "/user/hand/right/input/a",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/decrement" }
          }
        }
      ]
    }
  },
  "controller_type": "knuckles",
  "description": "Default bindings for XiloOVR",
  "name": "XiloOVR defaults (Index)"
}
