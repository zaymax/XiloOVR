{
  "bindings": {
    "/actions/main": {
      "sources": [
        {
          "path": "/user/hand/left/input/x",
          "mode": "button",
          "inputs": {
            "click": { "output": "/actions/main/in/toggle_panel" }
          }
        },
        {
          "path": "/user/hand/left/input/trigger",
          "mode": "trigger",
          "inputs": {
            "click": { "output": "/actions/main/in/interact" }
          }
        },
        {
          "path": "/user/hand/right/input/trigger",
          "mode": "trigger",
          "inputs": {
            "click": { "output": "/actions/main/in/interact" }
          }
        },
        {
          "path": "/user/hand/left/input/grip",
          "mode": "trigger",
          "inputs": {
            "click": { "output": "/actions/main/in/decrement" }
          }
        },
        {
          "path": "/user/hand/right/input/grip",
          "mode": "trigger",
          "inputs": {
            "click": { "output": "/actions/main/in/decrement" }
          }
        }
      ]
    }
  },
  "controller_type": "oculus_touch",
  "description": "Default bindings for XiloOVR",
  "name": "XiloOVR defaults (Touch)"
}
